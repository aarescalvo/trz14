# SOLEMAR ALIMENTARIA - Configuracion del Sistema
#
# INSTRUCCIONES:
#   1. Copiar este archivo como .env
#      En Windows: copy .env.example .env
#      En Linux/Mac: cp .env.example .env
#
#   2. Ajustar los valores segun tu entorno
#
#   3. NUNCA hacer commit del archivo .env al repositorio
#

# ============================================================
# BASE DE DATOS (REQUERIDO)
# ============================================================
# Para PRODUCCION (PostgreSQL):
DATABASE_URL="postgresql://postgres:1810@localhost:5432/trz5?schema=public"
#
# Para DESARROLLO local (SQLite) - NO usar en produccion:
# DATABASE_URL="file:./db/custom.db"

# ============================================================
# SEGURIDAD (REQUERIDO)
# ============================================================
# Clave secreta para JWT (tokens de sesion)
# IMPORTANTE: Cambiar por una clave segura en produccion
JWT_SECRET="traza123"

# ============================================================
# COOKIES (OPCIONAL)
# ============================================================
# Activar cookies seguras (solo con HTTPS)
# COOKIE_SECURE="true"

# ============================================================
# URL DE LA APLICACION (OPCIONAL)
# ============================================================
# URL base de la app (para links en emails, middleware, etc.)
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================================
# ENCRYPTACION (OPCIONAL)
# ============================================================
# Clave de encriptacion para datos sensibles (se genera automaticamente si no se pone)
# ENCRYPTION_KEY="tu-clave-de-32-caracteres-aqui"

# ============================================================
# BACKUPS (OPCIONAL)
# ============================================================
# Directorio para backups automaticos
# BACKUP_DIR="/home/z/my-project/backups"

# ============================================================
# VARIABLES DE ENTORNO (OPCIONAL)
# ============================================================
# NODE_ENV se configura automaticamente:
#   - "development" al correr con: npm run dev
#   - "production" al correr con: npm run build && npm start
